# =============================================================
# mattermost-gitops — Environment Configuration
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES
# .env is gitignored — NEVER commit it
# =============================================================

# ----- Git & GitHub -----
GITHUB_USER=your-github-username
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_REPO=mattermost-gitops
GITHUB_BRANCH=main

# ----- Cluster -----
CLUSTER_NAME=production
# CLUSTER_TYPE: "kind" for local dev/test | "kubeadm" for real on-prem server
CLUSTER_TYPE=kind

# ----- Networking -----
# For kind:    use 127.0.0.1
# For kubeadm: use your server's real public IP e.g. 203.0.113.10
SERVER_IP=127.0.0.1

# Your domain name
DOMAIN=modumichael.me

# Email for Let's Encrypt TLS certificates (on-prem only)
LETSENCRYPT_EMAIL=admin@modumichael.me

# ----- Secrets -----
# PostgreSQL database password (min 16 chars)
DB_PASSWORD=change-me-strong-password-here

# MinIO object storage credentials
MINIO_ACCESS_KEY=mattermost-minio
MINIO_SECRET_KEY=change-me-minio-secret-here

# MetalLB IP range — auto-detected by scripts, leave blank initially
METALLB_IP_RANGE=
